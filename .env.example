# .env.example

# The network for Solana deployment
VITE_SOLANA_NETWORK=mainnet

# API key for accessing Helius services
VITE_HELIUS_API_KEY=your_helius_api_key_here

# The RPC endpoint for connecting to Solana network
VITE_RPC_ENDPOINT=https://api.mainnet.solana.com

# The backend URL for the application
VITE_BACKEND_URL=http://localhost:3000